- Standard powertools handler skeleton (Day 10 — every Lambda):
    from common.observability import (
        get_logger, get_metrics, get_tracer,
        get_correlation_id, flush_metrics_early,
    )
    from aws_lambda_powertools.metrics import MetricUnit

    logger  = get_logger(service='bedrock-enrich')
    metrics = get_metrics(service='bedrock-enrich')
    tracer  = get_tracer(service='bedrock-enrich')

    @tracer.capture_lambda_handler
    @logger.inject_lambda_context(correlation_id_path='correlation_id', log_event=False)
    @metrics.log_metrics
    def handler(event, context):
        corr = get_correlation_id(event)
        logger.set_correlation_id(corr)
        metrics.add_metric(name='RecordsOk', unit=MetricUnit.Count, value=0)
        try:
            # ... business logic ...
            flush_metrics_early(metrics)        # before risky call
            result = invoke_bedrock(...)
            metrics.add_metric(name='RecordsOk', unit=MetricUnit.Count, value=1)
            return result
        except Exception:
            metrics.add_metric(name='RecordsErr', unit=MetricUnit.Count, value=1)
            raise

